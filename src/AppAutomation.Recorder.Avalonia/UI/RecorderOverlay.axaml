<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AppAutomation.Recorder.Avalonia.UI.RecorderOverlay">
    <UserControl.Styles>
        <Style Selector="UserControl">
            <Setter Property="Background" Value="{DynamicResource RecorderOverlayBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource RecorderOverlayBorder}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style Selector="UserControl">
            <Style.Resources>
                <SolidColorBrush x:Key="RecorderOverlayBackground">#F4F6F8</SolidColorBrush>
                <SolidColorBrush x:Key="RecorderOverlayBorder">#CBD5E1</SolidColorBrush>
                <SolidColorBrush x:Key="RecorderText">#0F172A</SolidColorBrush>
                <SolidColorBrush x:Key="RecorderAccent">#0F766E</SolidColorBrush>
                <SolidColorBrush x:Key="RecorderMuted">#475569</SolidColorBrush>
                <SolidColorBrush x:Key="RecorderWarning">#B45309</SolidColorBrush>
                <SolidColorBrush x:Key="RecorderDanger">#B91C1C</SolidColorBrush>
            </Style.Resources>
        </Style>

        <Style Selector="UserControl.dark-theme">
            <Style.Resources>
                <SolidColorBrush x:Key="RecorderOverlayBackground">#18212B</SolidColorBrush>
                <SolidColorBrush x:Key="RecorderOverlayBorder">#334155</SolidColorBrush>
                <SolidColorBrush x:Key="RecorderText">#E2E8F0</SolidColorBrush>
                <SolidColorBrush x:Key="RecorderAccent">#2DD4BF</SolidColorBrush>
                <SolidColorBrush x:Key="RecorderMuted">#CBD5E1</SolidColorBrush>
                <SolidColorBrush x:Key="RecorderWarning">#F59E0B</SolidColorBrush>
                <SolidColorBrush x:Key="RecorderDanger">#F87171</SolidColorBrush>
            </Style.Resources>
        </Style>
    </UserControl.Styles>

    <Border Padding="10">
        <StackPanel Spacing="8">
            <StackPanel x:Name="ExpandedPanel" Spacing="8">
                <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,*">
                    <Button x:Name="RecordButton"
                            Grid.Column="0"
                            Padding="10,4"
                            MinWidth="72"
                            Content="Record" />
                    <Button x:Name="ClearButton"
                            Grid.Column="1"
                            Margin="8,0,0,0"
                            Padding="10,4"
                            Content="Clear" />
                    <Button x:Name="SaveButton"
                            Grid.Column="2"
                            Margin="8,0,0,0"
                            Padding="10,4"
                            Content="Save" />
                    <Button x:Name="ExportButton"
                            Grid.Column="3"
                            Margin="8,0,0,0"
                            Padding="10,4"
                            Content="Export..." />
                    <Button x:Name="MinimizeButton"
                            Grid.Column="4"
                            Margin="8,0,0,0"
                            Padding="10,4"
                            Content="Minimize" />
                    <TextBlock x:Name="StepCounter"
                               Grid.Column="5"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource RecorderAccent}"
                               FontWeight="SemiBold"
                               Text="0 steps" />
                    <TextBlock x:Name="ValidationBadgeText"
                               Grid.Column="6"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Text="VALID" />
                    <TextBlock x:Name="StatusText"
                               Grid.Column="7"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource RecorderMuted}"
                               TextWrapping="Wrap"
                               MaxWidth="560" />
                </Grid>

                <TextBlock x:Name="PreviewText"
                           FontFamily="Cascadia Mono, Consolas"
                           Foreground="{DynamicResource RecorderText}"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="860" />

                <TextBlock x:Name="ShortcutText"
                           Foreground="{DynamicResource RecorderMuted}"
                           TextWrapping="Wrap"
                           MaxWidth="860" />
            </StackPanel>

            <Grid x:Name="MinimizedPanel"
                  IsVisible="False"
                  ColumnDefinitions="Auto,*">
                <Button x:Name="RestoreButton"
                        Grid.Column="0"
                        Padding="10,4"
                        Content="Restore" />
                <TextBlock x:Name="MinimizedStatusText"
                           Grid.Column="1"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource RecorderMuted}"
                           TextWrapping="Wrap"
                           MaxWidth="420" />
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
