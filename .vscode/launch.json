{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "C#: Dotnet Avalonia Debug",
            "type": "dotnet",
            "request": "launch",
            "projectPath": "${workspaceFolder}/sample/DotnetDebug.Avalonia/DotnetDebug.Avalonia.csproj"
        },
        {
            "name": "C#: Dotnet Avalonia Debug (MCP CoreCLR)",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/sample/DotnetDebug.Avalonia/bin/Debug/net10.0/DotnetDebug.Avalonia.dll",
            "cwd": "${workspaceFolder}/sample/DotnetDebug.Avalonia",
            "stopAtEntry": false,
            "preLaunchTask": "build-dotnetdebug-avalonia"
        },
        {
            "name": "C#: Dotnet Unit Tests Debug (MCP CoreCLR)",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/sample/DotnetDebug.Tests/bin/Debug/net10.0/DotnetDebug.Tests.exe",
            "cwd": "${workspaceFolder}/sample/DotnetDebug.Tests",
            "stopAtEntry": false,
            "preLaunchTask": "build-dotnetdebug-tests"
        },
        {
            "name": "C#: Dotnet UI Tests AppAutomation.FlaUI Debug (MCP CoreCLR)",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/sample/DotnetDebug.AppAutomation.FlaUI.Tests/bin/Debug/net10.0-windows7.0/DotnetDebug.AppAutomation.FlaUI.Tests.exe",
            "cwd": "${workspaceFolder}/sample/DotnetDebug.AppAutomation.FlaUI.Tests",
            "stopAtEntry": false,
            "preLaunchTask": "build-dotnetdebug-appautomation-flaui-tests"
        }
    ]
}
